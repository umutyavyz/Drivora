# Gmail SMTP
# 1) https://myaccount.google.com/security adresinden 2 adımlı doğrulamayı aç
# 2) https://myaccount.google.com/apppasswords adresinden "App Password" oluştur
# 3) 16 karakterlik şifreyi boşluksuz olarak SMTP_PASS'e yaz
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=umutyvz34@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
SMTP_FROM_NAME=Drivora

# Frontend URL — email içindeki linkler için
FRONTEND_URL=http://localhost:8100

# Sunucu portu (opsiyonel, varsayılan 3000)
# PORT=3000

# CORS — FRONTEND_URL + localhost dışında izin verilecek origin'ler (virgülle)
# Örn. LAN'dan telefonla test: CORS_ORIGINS=http://172.20.10.2:8100
# CORS_ORIGINS=

# SSL sertifika yolları (opsiyonel). Tanımlı/okunur değilse sunucu HTTP'ye düşer.
# SSL_KEY_PATH=./certs/key.pem
# SSL_CERT_PATH=./certs/cert.pem
